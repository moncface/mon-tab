{
  "manifest_version": 3,
  "name": "Mon [tab]",
  "version": "0.9.8",
  "description": "28 dev tools in Chrome's address bar. Type mon + Tab.",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" },
  "omnibox": { "keyword": "mon" },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": ["clipboardWrite", "offscreen", "storage"],
  "host_permissions": ["https://zipcloud.ibsnet.co.jp/*"]
}
