{
  "manifest_version": 3,
  "name": "Mon [tab]",
  "version": "0.9.10",
  "description": "28 dev tools in Chrome's address bar. Type mon + Tab.",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "action": {},
  "omnibox": { "keyword": "mon" },
  "options_ui": {
    "page": "chrome/options.html",
    "open_in_tab": true
  },
  "permissions": ["alarms", "clipboardWrite", "notifications", "offscreen", "storage"],
  "host_permissions": ["https://zipcloud.ibsnet.co.jp/*"]
}
